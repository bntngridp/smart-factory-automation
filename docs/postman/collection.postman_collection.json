              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [],
              "cookie": [],
              "body": "[\n  {\n    \"ProductID\": 1002,\n    \"ProductName\": \"Baut Industri M8\",\n    \"MinStock\": 500,\n    \"Unit\": \"pcs\"\n  },\n  {\n    \"ProductID\": 1003,\n    \"ProductName\": \"Sensor Suhu OMRON E5CC\",\n    \"MinStock\": 25,\n    \"Unit\": \"pcs\"\n  },\n  {\n    \"ProductID\": 1004,\n    \"ProductName\": \"PLC Mitsubishi FX5U\",\n    \"MinStock\": 10,\n    \"Unit\": \"unit\"\n  }\n]"
